# myEcho Monitoring (Prometheus + Grafana) — Umgebungsvariablen
# Kopieren nach `.env` (liegt neben docker-compose.yml) und ausfüllen:
#   cp .env.example .env
#
# Hinweis: Bei Deployment über Portainer werden diese Werte stattdessen
# im Stack-Editor unter "Environment variables" gesetzt.

# Admin-Passwort für die Grafana-Oberfläche.
# Default (wenn leer gelassen): myecho
GRAFANA_PASSWORD=myecho
