# myEcho Backend — Umgebungsvariablen
# Kopieren nach `.env` (liegt neben docker-compose.yml) und ausfüllen:
#   cp .env.example .env
#
# Hinweis: Bei Deployment über Portainer werden diese Werte stattdessen
# im Stack-Editor unter "Environment variables" gesetzt — dann ist keine
# .env-Datei nötig.

# Fish-Audio API-Key — PFLICHT. Ohne diesen Key liefert das Backend kein TTS.
# Anlegen unter: https://fish.audio  (Account -> API Keys)
TTS_API_KEY=

# TTS-Modell. Default ist s2-pro (kann meist so bleiben).
TTS_MODEL=s2-pro

# Fish-Audio Voice-/Reference-ID der gewünschten Stimme.
# Leer = Standardstimme des Modells.
TTS_VOICE=
